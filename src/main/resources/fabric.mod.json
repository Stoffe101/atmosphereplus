{
  "schemaVersion": 1,
  "id": "atmosphereplus",
  "version": "0.2.0-beta.3",
  "name": "Atmosphere+",
  "description": "Client-side visual atmosphere control suite: weather, time, fog, lighting, particles, clouds, profiles, presets, and Sodium/Iris-aware renderer controls.",
  "authors": [
    "Skrra",
    "Christoffer Lööf"
  ],
  "contact": {
    "homepage": "https://github.com/Stoffe101/AtmospherePlus",
    "sources": "https://github.com/Stoffe101/AtmospherePlus",
    "issues": "https://github.com/Stoffe101/AtmospherePlus/issues"
  },
  "license": "MIT",
  "icon": "assets/atmosphereplus/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.skrra.atmosphereplus.client.AtmospherePlusClient"
    ],
    "modmenu": [
      "com.skrra.atmosphereplus.compat.AtmosphereModMenuIntegration"
    ]
  },
  "mixins": [
    "atmosphereplus.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": ">=1.21.11 <1.21.12",
    "java": ">=21"
  },
  "suggests": {
    "fabric-api": "*",
    "modmenu": "*",
    "sodium": "*",
    "iris": "*"
  },
  "custom": {
    "modmenu": {
      "badges": [
        "client"
      ]
    }
  }
}
